{
  "name": "@nanostores/react",
  "version": "1.1.0",
  "description": "React integration for Nano Stores, a tiny state manager with many atomic tree-shakable stores",
  "keywords": [
    "react",
    "react native",
    "state",
    "state manager",
    "store"
  ],
  "license": "MIT",
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "repository": "nanostores/react",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test:lint": "oxlint .",
    "test:coverage": "pnpm bnt --coverage",
    "test:types": "check-dts",
    "test:size": "size-limit",
    "test": "pnpm run /^test:/"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "actions-up": "^1.14.3",
    "better-node-test": "^0.8.4",
    "check-dts": "^1.0.0",
    "happy-dom": "^20.10.6",
    "nanodelay": "^2.0.2",
    "nanostores": "^1.3.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "nanostores": "^1.2.0",
    "react": ">=18.0.0"
  },
  "size-limit": [
    {
      "import": {
        "index.js": "{ useStore }",
        "nanostores": "{ map, computed }"
      },
      "limit": "983 B"
    }
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  }
}
